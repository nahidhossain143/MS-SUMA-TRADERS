# ============================
# MS SUMA TRADERS — .gitignore
# ============================

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment secrets — NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
*.swp

# IDE
.vscode/settings.json
.idea/

# Uploads (local file storage — use cloud storage in production)
server/uploads/*
!server/uploads/.gitkeep

# Prisma
server/prisma/dev.db
server/prisma/dev.db-journal

# Misc
*.tgz
.npm
